# Backend environment variables
# Copy this file to .env and fill in real values.

# MongoDB connection string (REQUIRED - app will not start without it)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/Mezbaan

# Razorpay payment gateway (required for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google OAuth (optional but recommended for Sign-In audience verification)
GOOGLE_CLIENT_ID=
# JWT signing secret for session tokens (change from default in production)
GOOGLE_TOKEN_SECRET=mezbaan-google-secret-2026

# Supabase (required for Email OTP auth verification)
SUPABASE_URL=
SUPABASE_ANON_KEY=
