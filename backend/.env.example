# Backend environment variables
# Copy this file to .env and fill in real values.

# MongoDB connection string (REQUIRED - app will not start without it)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/Mezbaan

# Razorpay payment gateway (required for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google OAuth (optional but recommended for Sign-in audience verification)
GOOGLE_CLIENT_ID=
# JWT signing secret for session tokens (change from default in production)
GOOGLE_TOKEN_SECRET=mezbaan-google-secret-2026

# Supabase (required for Email + Password auth verification)
# Must match the Supabase project used by the frontend
SUPABASE_URL=https://jppuqbujxtmemusmbgnv.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase Cloud Messaging (FCM) — required for admin push notifications
# Get this from Firebase Console > Project Settings > Cloud Messaging > Server Key
FCM_SERVER_KEY=
