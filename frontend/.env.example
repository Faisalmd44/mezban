# Frontend environment variables
# Copy this file to .env and fill in real values.
# Variables must be prefixed with EXPO_PUBLIC_ to be exposed to the app.

# Backend API URL (REQUIRED for app to fetch menu/orders)
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000

# Google OAuth Web Client ID (required for Google Sign-In)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
