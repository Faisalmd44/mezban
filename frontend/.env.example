# Frontend environment variables
# Copy this file to .env and fill in real values.
# Variables must be prefixed with EXPO_PUBLIC_ to be exposed to the app.

# Backend API URL (REQUIRED for app to fetch menu/orders)
EXPO_PUBLIC_BACKEND_URL=https://mezban-production-56bc.up.railway.app

# Google OAuth Web Client ID (required for Google Sign-In)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Supabase (required for Email + Password authentication)
EXPO_PUBLIC_SUPABASE_URL=https://prywmtaihoekfresswmx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
